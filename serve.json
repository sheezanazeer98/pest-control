{
  "cleanUrls": false,
  "headers": [
    {
      "source": "**/*.yml",
      "headers": [
        { "key": "Content-Type", "value": "text/yaml" }
      ]
    },
    {
      "source": "**/*.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown" }
      ]
    },
    {
      "source": "**/*.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "**/*.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin/**", "destination": "/admin/index.html" },
    { "source": "/**", "destination": "/index.html" }
  ]
}
